ARG RUST_IMAGE=rust:1.93.0-slim-bookworm
ARG RUNTIME_IMAGE=debian:bookworm-slim

FROM ${RUST_IMAGE} AS builder

RUN apt-get update \
    && apt-get install -y --no-install-recommends pkg-config libssl-dev ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace
COPY rust ./rust
RUN cargo build --manifest-path rust/apps/ja_control_plane/Cargo.toml --release

FROM ${RUNTIME_IMAGE}

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY --from=builder /workspace/rust/target/release/ja_control_plane /usr/local/bin/ja_control_plane

ENTRYPOINT ["ja_control_plane", "server"]
