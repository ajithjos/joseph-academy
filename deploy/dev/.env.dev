JOSEPH_DEV_COMPOSE_PROJECT_NAME=joseph-academy-dev

JOSEPH_WORKSPACE_HOST=__REPO_ROOT__
JOSEPH_DEV_LOCAL_ROOT=__REPO_ROOT__/scratchpad/dev/local
