# deploy/dev/.env.dev
#
# Tracked defaults for the Cornerstone local compose stack.
#
# Optional local overrides:
#   create deploy/dev/.env if you want machine-specific changes.

CORNERSTONE_DEV_COMPOSE_PROJECT_NAME=cornerstone-dev

CORNERSTONE_WORKSPACE_HOST=__REPO_ROOT__
CORNERSTONE_DEV_LOCAL_ROOT=__REPO_ROOT__/scratchpad/dev/local
# Rotate this revision when tracked Postgres defaults become incompatible with
# older local data so compose boots into a fresh local data window.
CORNERSTONE_DEV_DATA_REVISION=01

CORNERSTONE_POSTGRES_PORT=55433
CORNERSTONE_CONTROL_PLANE_PORT=8788
CORNERSTONE_FRONTEND_PORT=8080
CORNERSTONE_DOCS_SITE_PORT=3001
CORNERSTONE_COMPOSE_WAIT_TIMEOUT=120

CORNERSTONE_POSTGRES_DB=cornerstone
CORNERSTONE_POSTGRES_ADMIN_USER=cornerstone_admin
CORNERSTONE_POSTGRES_ADMIN_PASSWORD=cornerstone_admin_dev_password
CORNERSTONE_POSTGRES_APP_USER=cornerstone_app
CORNERSTONE_POSTGRES_APP_PASSWORD=cornerstone_app_dev_password

CORNERSTONE_POSTGRES_DATA_HOST=__CORNERSTONE_DEV_LOCAL_ROOT__/data/__CORNERSTONE_DEV_DATA_REVISION__/postgres
CORNERSTONE_ARTIFACTS_HOST=__CORNERSTONE_DEV_LOCAL_ROOT__/data/__CORNERSTONE_DEV_DATA_REVISION__/artifacts
CORNERSTONE_EXPORTS_HOST=__CORNERSTONE_DEV_LOCAL_ROOT__/data/__CORNERSTONE_DEV_DATA_REVISION__/exports
