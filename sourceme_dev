# bootstrap: uv sync --all-extras

uvsync() {
	if command -v uv >/dev/null 2>&1; then
		echo "Running: uv sync --all-extras"
		uv sync --all-extras || return $?
	else
		echo "uv command not found. Install uv first."
		return 1
	fi
}

if [ -f .venv/bin/activate ]; then
	source .venv/bin/activate
else
	echo "Warning: .venv not found. Run 'uv sync --all-extras' if you want the repo-managed Python environment."
fi

if [ -n "${ZSH_VERSION:-}" ]; then
	SCRIPT_PATH="${(%):-%x}"
	SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" >/dev/null 2>&1 && pwd)"
else
	SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" >/dev/null 2>&1 && pwd)"
fi

export CORNERSTONE_REPO_ROOT="$SCRIPT_DIR"

source_env_file() {
	file="$1"
	[ -f "$file" ] || return 0
	set -a
	. "$file"
	set +a
}

resolve_tokens() {
	value="$1"
	value="${value//__REPO_ROOT__/$CORNERSTONE_REPO_ROOT}"
	value="${value//__HOME__/$HOME}"
	value="${value//__CORNERSTONE_DEV_LOCAL_ROOT__/$CORNERSTONE_DEV_LOCAL_ROOT}"
	value="${value//__CORNERSTONE_DEV_DATA_REVISION__/$CORNERSTONE_DEV_DATA_REVISION}"
	printf '%s' "$value"
}

source_env_file "$SCRIPT_DIR/deploy/dev/.env.dev"
source_env_file "$SCRIPT_DIR/deploy/dev/.env"

: "${CORNERSTONE_DEV_LOCAL_ROOT:?CORNERSTONE_DEV_LOCAL_ROOT must be set in deploy/dev/.env.dev or deploy/dev/.env}"
: "${CORNERSTONE_DEV_DATA_REVISION:?CORNERSTONE_DEV_DATA_REVISION must be set in deploy/dev/.env.dev or deploy/dev/.env}"
: "${CORNERSTONE_POSTGRES_PORT:?CORNERSTONE_POSTGRES_PORT must be set in deploy/dev/.env.dev or deploy/dev/.env}"
: "${CORNERSTONE_CONTROL_PLANE_PORT:?CORNERSTONE_CONTROL_PLANE_PORT must be set in deploy/dev/.env.dev or deploy/dev/.env}"
: "${CORNERSTONE_FRONTEND_PORT:?CORNERSTONE_FRONTEND_PORT must be set in deploy/dev/.env.dev or deploy/dev/.env}"
: "${CORNERSTONE_DOCS_SITE_PORT:?CORNERSTONE_DOCS_SITE_PORT must be set in deploy/dev/.env.dev or deploy/dev/.env}"
: "${CORNERSTONE_POSTGRES_DB:?CORNERSTONE_POSTGRES_DB must be set in deploy/dev/.env.dev or deploy/dev/.env}"
: "${CORNERSTONE_POSTGRES_APP_USER:?CORNERSTONE_POSTGRES_APP_USER must be set in deploy/dev/.env.dev or deploy/dev/.env}"
: "${CORNERSTONE_POSTGRES_APP_PASSWORD:?CORNERSTONE_POSTGRES_APP_PASSWORD must be set in deploy/dev/.env.dev or deploy/dev/.env}"
: "${CORNERSTONE_ARTIFACTS_HOST:?CORNERSTONE_ARTIFACTS_HOST must be set in deploy/dev/.env.dev or deploy/dev/.env}"
: "${CORNERSTONE_EXPORTS_HOST:?CORNERSTONE_EXPORTS_HOST must be set in deploy/dev/.env.dev or deploy/dev/.env}"

export CORNERSTONE_DEV_LOCAL_ROOT="$(resolve_tokens "$CORNERSTONE_DEV_LOCAL_ROOT")"
export CORNERSTONE_ARTIFACTS_ROOT="$(resolve_tokens "$CORNERSTONE_ARTIFACTS_HOST")"
export CORNERSTONE_EXPORTS_ROOT="$(resolve_tokens "$CORNERSTONE_EXPORTS_HOST")"
export CORNERSTONE_CONTENT_ROOT="$SCRIPT_DIR/content"
export CORNERSTONE_BOOTSTRAP_FILE="$SCRIPT_DIR/deploy/config/runtime_defaults/identity_bootstrap.yaml"
export CORNERSTONE_BIND_ADDRESS="0.0.0.0:$CORNERSTONE_CONTROL_PLANE_PORT"
export CORNERSTONE_DATABASE_URL="postgres://$CORNERSTONE_POSTGRES_APP_USER:$CORNERSTONE_POSTGRES_APP_PASSWORD@127.0.0.1:$CORNERSTONE_POSTGRES_PORT/$CORNERSTONE_POSTGRES_DB"
export CORNERSTONE_AUTO_BOOTSTRAP="true"
export CORNERSTONE_FRONTEND_PUBLIC_URL="http://127.0.0.1:$CORNERSTONE_FRONTEND_PORT"
export CORNERSTONE_API_URL="http://127.0.0.1:$CORNERSTONE_CONTROL_PLANE_PORT"
export CORNERSTONE_FRONTEND_URL="$CORNERSTONE_FRONTEND_PUBLIC_URL"
export CORNERSTONE_DOCS_URL="http://127.0.0.1:$CORNERSTONE_DOCS_SITE_PORT"
export CORNERSTONE_DEVELOPER_DOCS_URL="$CORNERSTONE_DOCS_URL"

mkdir -p "$CORNERSTONE_ARTIFACTS_ROOT" "$CORNERSTONE_EXPORTS_ROOT"

echo
echo "Set repo_root as: $CORNERSTONE_REPO_ROOT"
echo "Set content_root as: $CORNERSTONE_CONTENT_ROOT"
echo "Set bootstrap_file as: $CORNERSTONE_BOOTSTRAP_FILE"
echo "Set artifacts_root as: $CORNERSTONE_ARTIFACTS_ROOT"
echo "Set exports_root as: $CORNERSTONE_EXPORTS_ROOT"
echo "Set database_url as: $CORNERSTONE_DATABASE_URL"
echo "Set api_url as: $CORNERSTONE_API_URL"
echo "Set frontend_url as: $CORNERSTONE_FRONTEND_URL"
echo "Set docs_url as: $CORNERSTONE_DOCS_URL"
