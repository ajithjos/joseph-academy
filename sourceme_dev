# bootstrap: uv sync --all-extras

uvsync() {
	if command -v uv >/dev/null 2>&1; then
		echo "Running: uv sync --all-extras"
		uv sync --all-extras || return $?
	else
		echo "uv command not found. Install uv first."
		return 1
	fi
}

if [ -f .venv/bin/activate ]; then
	source .venv/bin/activate
else
	echo "Warning: .venv not found. Run 'uv sync --all-extras' if you want the repo-managed Python environment."
fi

if [ -n "${ZSH_VERSION:-}" ]; then
	SCRIPT_PATH="${(%):-%x}"
	SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" >/dev/null 2>&1 && pwd)"
else
	SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" >/dev/null 2>&1 && pwd)"
fi

export CORNERSTONE_REPO_ROOT="$SCRIPT_DIR"
export CORNERSTONE_CONTENT_ROOT="${CORNERSTONE_CONTENT_ROOT:-$SCRIPT_DIR/content}"
export CORNERSTONE_BOOTSTRAP_FILE="${CORNERSTONE_BOOTSTRAP_FILE:-$SCRIPT_DIR/deploy/config/runtime_defaults/identity_bootstrap.yaml}"
export CORNERSTONE_ARTIFACTS_ROOT="${CORNERSTONE_ARTIFACTS_ROOT:-$SCRIPT_DIR/scratchpad/dev/local/data/01/artifacts}"
export CORNERSTONE_EXPORTS_ROOT="${CORNERSTONE_EXPORTS_ROOT:-$SCRIPT_DIR/scratchpad/dev/local/data/01/exports}"
export CORNERSTONE_DATABASE_URL="${CORNERSTONE_DATABASE_URL:-postgres://cornerstone_app:cornerstone_app_dev_password@127.0.0.1:55433/cornerstone}"
export CORNERSTONE_API_URL="${CORNERSTONE_API_URL:-http://127.0.0.1:8788}"
export CORNERSTONE_FRONTEND_URL="${CORNERSTONE_FRONTEND_URL:-http://127.0.0.1:8080}"
export CORNERSTONE_DOCS_URL="${CORNERSTONE_DOCS_URL:-http://127.0.0.1:3001}"

mkdir -p "$CORNERSTONE_ARTIFACTS_ROOT" "$CORNERSTONE_EXPORTS_ROOT"

echo
echo "Set repo_root as: $CORNERSTONE_REPO_ROOT"
echo "Set content_root as: $CORNERSTONE_CONTENT_ROOT"
echo "Set bootstrap_file as: $CORNERSTONE_BOOTSTRAP_FILE"
echo "Set artifacts_root as: $CORNERSTONE_ARTIFACTS_ROOT"
echo "Set exports_root as: $CORNERSTONE_EXPORTS_ROOT"
echo "Set database_url as: $CORNERSTONE_DATABASE_URL"
echo "Set api_url as: $CORNERSTONE_API_URL"
echo "Set frontend_url as: $CORNERSTONE_FRONTEND_URL"
echo "Set docs_url as: $CORNERSTONE_DOCS_URL"
