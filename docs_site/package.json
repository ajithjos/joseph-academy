{
  "name": "cornerstone-docs-site",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "prepare": "npm run prepare:production",
    "prepare:production": "uv run python ../scripts/render_catalog_docs.py production",
    "prepare:developer": "uv run python ../scripts/render_catalog_docs.py developer",
    "start": "npm run start:developer",
    "start:developer": "npm run prepare:developer && docusaurus start --host 0.0.0.0 --port 3001",
    "start:production": "npm run prepare:production && docusaurus start --host 0.0.0.0 --port 3002",
    "build": "npm run build:production",
    "build:production": "npm run prepare:production && docusaurus build --out-dir build/production",
    "build:developer": "npm run prepare:developer && docusaurus build --out-dir build/developer",
    "serve:production": "docusaurus serve build/production --host 0.0.0.0 --port 3003",
    "serve:developer": "docusaurus serve build/developer --host 0.0.0.0 --port 3004"
  },
  "dependencies": {
    "@docusaurus/core": "3.10.1",
    "@docusaurus/preset-classic": "3.10.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
